2️⃣ Dynamic expressions in jOOQ
Field<?> buildExpression(String alias, String expr) {
    // Use DSL.field(String sql, Class<?> type)
    return DSL.field(expr).as(alias);
}

Example:

Field<String> upperName = buildExpression("upper_name", "UPPER(name)");
3️⃣ Dynamic joins
Table<?> joinTable(String joinType, String tableName, String onCondition) {
    Table<?> t = DSL.table(DSL.name(tableName));
    switch(joinType.toUpperCase()) {
        case "INNER": return t.as("t").join(t).on(DSL.condition(onCondition));
        case "LEFT": return t.as("t").leftJoin(t).on(DSL.condition(onCondition));
        case "RIGHT": return t.as("t").rightJoin(t).on(DSL.condition(onCondition));
        default: throw new IllegalArgumentException("Unsupported join type: " + joinType);
    }
}

Note: In practice, you may need to merge multiple joins; jOOQ allows chaining .join(...).on(...).

4️⃣ Table-valued functions (TVFs)

If a table comes from a function:

Table<?> customerOrders = DSL.table(DSL.name("customer_orders(?)"), customerId)
                             .as("co");
You can then join or select from customerOrders like a regular table.
5️⃣ Putting it all together (simplified skeleton)
public SelectQuery<?> buildDynamicQuery(DSLContext create, QuerySpec spec) {
    Table<?> table = DSL.table(spec.entity);

    SelectQuery<?> query = create.selectQuery();

    // Columns
    if(spec.columns != null) {
        for(String col : spec.columns) {
            query.addSelect(DSL.field(name(col)));
        }
    }

    // Expressions
    if(spec.expressions != null) {
        for(var exp : spec.expressions) {
            query.addSelect(buildExpression(exp.alias, exp.expr));
        }
    }

    // Aggregations
    if(spec.aggregations != null) {
        for(var agg : spec.aggregations) {
            query.addSelect(buildAggregation(agg));
        }
    }

    query.addFrom(table);

    // Joins
    if(spec.joins != null) {
        for(var j : spec.joins) {
            query.addJoin(DSL.table(j.table), JoinType.valueOf(j.type.toUpperCase()),
                          DSL.condition(j.on));
        }
    }

    // Filters
    if(spec.filters != null) {
        for(var f : spec.filters) {
            if(f.expr != null) {
                query.addConditions(DSL.condition(f.expr));
            } else {
                query.addConditions(buildCondition(f.field, f.op, f.value));
            }
        }
    }

    // Group by
    if(spec.group_by != null) {
        List<Field<?>> groupFields = spec.group_by.stream().map(c -> DSL.field(name(c))).toList();
        query.addGroupBy(groupFields);
    }

    // Sort
    if(spec.sort != null) {
        for(var s : spec.sort) {
            Field<Object> f = DSL.field(name(s.field));
            query.addOrderBy("ASC".equalsIgnoreCase(s.dir) ? f.asc() : f.desc());
        }
    }

    // Limit
    if(spec.limit != null) {
        query.addLimit(spec.limit);
    }

    return query;
}
