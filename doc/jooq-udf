1️⃣ Define the JSON structures in Java
import java.util.List;
import java.util.Map;

public class QuerySpec {
    public String entity;
    public List<String> columns; // plain columns
    public List<Aggregation> aggregations; // aggregated fields
    public List<Filter> filters; // where conditions
    public List<String> group_by;
    public List<Sort> sort;
    public Integer limit;
}

public class Aggregation {
    public String field;
    public String func; // AVG, SUM, COUNT, MIN, MAX
}

public class Filter {
    public String field;
    public String op; // >, <, =, etc
    public Object value;
}

public class Sort {
    public String field;
    public String dir; // ASC or DESC
}
2️⃣ Helper method to create conditions dynamically
import org.jooq.Condition;
import org.jooq.Field;
import static org.jooq.impl.DSL.field;

public Condition buildCondition(String fieldName, String op, Object value) {
    Field<Object> f = field(name(fieldName));
    switch(op) {
        case ">": return f.gt(value);
        case "<": return f.lt(value);
        case "=": return f.eq(value);
        case ">=": return f.ge(value);
        case "<=": return f.le(value);
        case "!=": return f.ne(value);
        default: throw new IllegalArgumentException("Unsupported operator: " + op);
    }
}
3️⃣ Build fields dynamically for aggregations
import org.jooq.Field;
import static org.jooq.impl.DSL.*;

public Field<?> buildAggregation(Aggregation agg) {
    Field<Object> f = field(name(agg.field));
    switch(agg.func.toUpperCase()) {
        case "AVG": return f.avg().as(agg.field + "_avg");
        case "SUM": return f.sum().as(agg.field + "_sum");
        case "COUNT": return f.count().as(agg.field + "_count");
        case "MIN": return f.min().as(agg.field + "_min");
        case "MAX": return f.max().as(agg.field + "_max");
        default: throw new IllegalArgumentException("Unsupported aggregation: " + agg.func);
    }
}
4️⃣ Putting it all together
import org.jooq.*;
import org.jooq.impl.DSL;
import java.util.ArrayList;
import java.util.List;

public ResultQuery<?> buildQuery(DSLContext create, QuerySpec spec) {
    Table<?> table = table(name(spec.entity));
    List<Field<?>> selectFields = new ArrayList<>();

    // Plain columns
    if(spec.columns != null) {
        for(String col : spec.columns) {
            selectFields.add(field(name(col)));
        }
    }

    // Aggregations
    if(spec.aggregations != null) {
        for(Aggregation agg : spec.aggregations) {
            selectFields.add(buildAggregation(agg));
        }
    }

    // Start building query
    SelectSelectStep<?> queryStep = create.select(selectFields);
    SelectJoinStep<?> queryFrom = queryStep.from(table);

    // Filters
    if(spec.filters != null && !spec.filters.isEmpty()) {
        Condition cond = null;
        for(Filter f : spec.filters) {
            Condition c = buildCondition(f.field, f.op, f.value);
            cond = cond == null ? c : cond.and(c);
        }
        queryFrom = queryFrom.where(cond);
    }

    // Group by
    if(spec.group_by != null && !spec.group_by.isEmpty()) {
        List<Field<?>> groupByFields = new ArrayList<>();
        for(String g : spec.group_by) groupByFields.add(field(name(g)));
        queryFrom = queryFrom.groupBy(groupByFields);
    }

    // Sorting
    if(spec.sort != null && !spec.sort.isEmpty()) {
        List<SortField<?>> orderByFields = new ArrayList<>();
        for(Sort s : spec.sort) {
            Field<Object> f = field(name(s.field));
            orderByFields.add("ASC".equalsIgnoreCase(s.dir) ? f.asc() : f.desc());
        }
        queryFrom = queryFrom.orderBy(orderByFields);
    }

    // Limit
    if(spec.limit != null) {
        queryFrom = queryFrom.limit(spec.limit);
    }

    return queryFrom;
}
